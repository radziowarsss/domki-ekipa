# Skopiuj do .env (lokalnie) lub ustaw w Netlify → Site settings → Environment variables

# Auto-deploy przez netlify-cli (loop). Token: netlify.com → User settings → Applications → Personal access tokens
NETLIFY_AUTH_TOKEN=

# Hasło wejścia do apki (bramka dla ekipy)
APP_PASSWORD=ekipa2026

# Sekret do podpisywania cookie/JWT — WYGENERUJ losowy ciąg (np. openssl rand -hex 32)
JWT_SECRET=
